# ─────────────────────────────────────────────────────────────────────────────
# Mike — production environment template
#
# Copy to .env.prod and fill in ALL required values:
#   cp .env.prod.example .env.prod
#
# IMPORTANT: Replace every placeholder below before deploying.
# Never commit .env.prod to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres ──────────────────────────────────────────────────────────────────
# Strong random password — generate with:  openssl rand -hex 32
POSTGRES_PASSWORD=change-me-strong-random-password

# ── JWT / Supabase keys ───────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 40
JWT_SECRET=change-me-super-secret-jwt-token-with-at-least-32-characters

# Sign these JWTs with your JWT_SECRET using https://jwt.io or the helper in
# docs/deployment.md.  Payload for ANON_KEY:  { "role": "anon", "iss": "supabase" }
# Payload for SERVICE_ROLE_KEY: { "role": "service_role", "iss": "supabase" }
ANON_KEY=<your-anon-jwt>
SERVICE_ROLE_KEY=<your-service-role-jwt>

# ── Auth (GoTrue) ─────────────────────────────────────────────────────────────
# Public URL of your Mike instance (as users see it in the browser)
SITE_URL=https://mike.example.com

# Public URL of the Supabase gateway (API gateway, typically port 8000 or behind
# a reverse proxy).  Must be reachable by the browser for auth flows.
API_EXTERNAL_URL=https://api.mike.example.com

# Disable email auto-confirm in production (require users to verify their email)
ENABLE_EMAIL_AUTOCONFIRM=false

DISABLE_SIGNUP=false

# SMTP settings for auth emails (password reset, signup confirmation, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user@example.com
SMTP_PASS=smtp-password
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_SENDER_NAME=Mike

# ── MinIO (S3-compatible object storage) ──────────────────────────────────────
# Use strong, unique credentials
MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-password
R2_BUCKET_NAME=mike

# ── GHCR image tag ────────────────────────────────────────────────────────────
# Tag to pull from GHCR.  "latest" tracks the default branch.
IMAGE_TAG=latest

# ── AI model keys (at least one required) ────────────────────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ── Email (Resend) — optional ─────────────────────────────────────────────────
RESEND_API_KEY=
