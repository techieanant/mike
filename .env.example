# ─────────────────────────────────────────────────────────────────────────────
# Mike — local development environment template
#
# Copy to .env and fill in the required values:
#   cp .env.example .env
#
# The ANON_KEY and SERVICE_ROLE_KEY below are the standard Supabase self-hosted
# demo keys. They are signed with the JWT_SECRET shown here.
# REPLACE ALL OF THESE for any non-throwaway environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres

# ── JWT / Supabase keys ───────────────────────────────────────────────────────
# Generate a new secret with:  openssl rand -base64 40
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Pre-generated JWTs for the JWT_SECRET above.
# These example tokens expire 2027-01-10. Regenerate them (see
# docs/local-development.md) before using this stack beyond local throwaway dev.
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.dc_X5iR_VP_qroESr-4V2_YPmPgAVQ7IYTZ9v66bEdI
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTY0MTc2OTIwMCwiZXhwIjoxNzk5NTM1NjAwfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q

# ── Auth (GoTrue) ──────────────────────────────────────────────────────────────
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:8000

# Email auto-confirm (true = skip email verification; useful for local dev)
ENABLE_EMAIL_AUTOCONFIRM=true

# SMTP — leave blank to skip email sending entirely in local dev
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_SENDER_NAME=Mike

# ── MinIO (local S3-compatible storage) ───────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
R2_BUCKET_NAME=mike

# ── Next.js public vars (baked in at build time) ──────────────────────────────
# SUPABASE_URL as seen by the browser (must be publicly reachable)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.dc_X5iR_VP_qroESr-4V2_YPmPgAVQ7IYTZ9v66bEdI
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# ── Frontend / Backend URLs ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── AI model keys (at least one required for AI features) ────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ── Email (Resend) — optional ─────────────────────────────────────────────────
RESEND_API_KEY=
